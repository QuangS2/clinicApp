# =========================================================================
# Work Process & Documentation Files
# =========================================================================
# Ignore work-process/temporary markdown files, task lists, and plan files
*.md
!README.md
!**/README.md
!CHANGELOG.md
!**/CHANGELOG.md
!CONTRIBUTING.md
!**/CONTRIBUTING.md
project_rules.md
agent.md

# Also ignore specific directories used for documentation/notes/guides
guide/
mindmap/
docs/
*.txt

# =========================================================================
# Java & Maven (Backend)
# =========================================================================
# Ignore Maven build output directory
target/
**/target/

# Ignore compiled class files
*.class
**/*.class

# Ignore packaged outputs
*.jar
*.war
*.ear

# Secrets and local configuration
application_secrets.properties
**/application_secrets.properties

# =========================================================================
# Node & Frontend (Backup settings for root)
# =========================================================================
# Ignore dependency directories
node_modules/
**/node_modules/

# Ignore build outputs
dist/
**/dist/
dist-ssr/
**/dist-ssr/

# Ignore environment variables and local configs
.env*.local
*.local

# =========================================================================
# IDEs, Editors & System Files
# =========================================================================
# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Eclipse
.metadata/
.classpath
.project
.settings/
.factorypath

# OS files
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.bak
*.swp
*~

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
